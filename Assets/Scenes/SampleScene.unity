  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u042D\u043F\u0438\u0437\u043E\u0434 101: \u0417\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u0435
    \u0445\u0430\u043A\u0430\u0442\u043E\u043D\u0430\n\n\n\u0414\u0430\u0432\u043D\u044B\u043C-\u0434\u0430\u0432\u043D\u043E,
    \n\u0432 \u0440\u0435\u043F\u043E\u0437\u0438\u0442\u043E\u0440\u0438\u0438 \u0434\u0430\u043B\u0435\u043A\u043E\u043C...\r\n\u041F\u0440\u043E\u0442\u043E\u043A\u043E\u043B
    OASIS \u0425\u043E\u043B\u043B\u0438\u0434\u0435\u0439 \u0441\u043A\u0440\u044B\u043B.
    \n\u041A\u043E\u0434 \u043B\u0430\u043F\u0448\u043E\u0439 \u043D\u0430\u043F\u0438\u0441\u0430\u043D,
    \n\u0431\u0430\u0433\u043E\u0432 \u043C\u043D\u043E\u0433\u043E \u0432 \u043D\u0435\u043C.\r\n\u0425\u0430\u043A\u0430\u0442\u043E\u043D\u0430
    \u0434\u0435\u0434\u043B\u0430\u0439\u043D \u0431\u043B\u0438\u0437\u043E\u043A!\r\n\u041A\u043B\u0438\u043D\u043A\u043E\u043C
    \u0441\u0432\u043E\u0438\u043C (\u041C\u044B\u0448\u044C) \n\u043F\u0443\u043B\u0438
    \u043A\u0440\u0430\u0441\u043D\u044B\u0435 \u043E\u0442\u0440\u0430\u0436\u0430\u0439
    \u0442\u044B. \n\u0417\u0435\u043B\u0435\u043D\u044B\u043C\u0438 \u0441\u0442\u0430\u0442\u044C
    \u043E\u043D\u0438 \u0434\u043E\u043B\u0436\u043D\u044B,\n\u0448\u0442\u0443\u0440\u043C\u043E\u0432\u0438\u043A\u043E\u0432
    \u0440\u0430\u0437\u044F.\r\n\u0421\u0438\u043B\u0443 (Space) \u043A\u043E\u043F\u0438,\n\u043A\u043E\u0433\u0434\u0430
    \u0427\u0435\u0440\u0432\u044C \u041A\u043E\u0441\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u0440\u0438\u0434\u0435\u0442.\n\u041A\u0440\u0443\u0442\u0438\u0441\u044C
    (E), \u043A\u0430\u043A \u0431\u0435\u043B\u043A\u0430 \u0432 \u043A\u043E\u043B\u0435\u0441\u0435,\n
    \u0432\u0440\u0430\u0433\u043E\u0432 \u0448\u0438\u043D\u043A\u0443\u044F.\r\n\u0417\u043E\u043B\u043E\u0442\u043E\u0435
    \u042F\u0439\u0446\u043E \u043D\u0430 15 \u0443\u0440\u043E\u0432\u043D\u0435\n\u043D\u0430\u0439\u0442\u0438
    \u0434\u043E\u043B\u0436\u0435\u043D \u0442\u044B.\r\n\n\u041F\u043E\u0442\u043E\u0440\u043E\u043F\u0438\u0441\u044C!
    \u0412\u0440\u0435\u043C\u044F \u2014 \u044D\u0442\u043E \u043A\u043E\u043C\u043C\u0438\u0442\r\n\u0414\u0430
    \u043F\u0440\u0435\u0431\u0443\u0434\u0435\u0442 \u0441 \u0442\u043E\u0431\u043E\u0439
    \u0421\u0438\u043B\u0430\n \u0438 \u0441\u0442\u0430\u0431\u0438\u043B\u044C\u043D\u044B\u0439
    \u0431\u0438\u043B\u0434!"
